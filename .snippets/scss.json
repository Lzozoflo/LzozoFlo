{
	"Print to console": {
		"prefix": "dflex",
		"body": [
			"display: flex;",
			"flex-direction: row;",
			"justify-content: center;",
			"align-items: center;",
			"$1"
		],
		"description": "Log output to console"
	},
	"include": {
		"prefix": "inclu",
		"body": [
			"@include mix.$1($2);"
		],
		"description": "mixin scss include"
	},
	"use": {
		"prefix": "use",
		"body": [
			"@use 'STYLE/mixin' as mix;",
			"@use 'STYLE/_variable' as *;"
		],
		"description": "mixin scss include"
	},
	"addheader": {
		"prefix": "header",
		"body": [
			"@use 'STYLE/mixin' as mix;",
			"@use 'STYLE/_variable' as *;",
			"",
			".$1-root{",
    		"   @include mix.full();",
    		"   @include mix.center();",
			"",
			"$0",
			"}"
		],
		"description": "Log output to console"
	}
}